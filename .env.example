# Clerk (https://dashboard.clerk.com -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Supabase Postgres connection string (Supabase -> Project Settings -> Database)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Novu (in-app notifications) - https://dashboard.novu.co -> Settings -> Application Identifier
NEXT_PUBLIC_NOVU_APPLICATION_IDENTIFIER=UddPezGtB8uw

# Clerk paths (must match the Account Portal fields in the dashboard)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Where to land after auth
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Sign-out path -> set via <ClerkProvider afterSignOutUrl="..."> (not an env var)
# Development host -> set in the Clerk Dashboard Account Portal (not an env var)
